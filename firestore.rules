rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidVisit(data) {
      return data.keys().hasAll(['salesAdvisor', 'customerNumber', 'company', 'businessName', 'latitude', 'longitude', 'createdAt', 'userId']) 
             && data.keys().size() <= 9 
             && data.salesAdvisor is string && data.salesAdvisor.size() <= 500
             && data.customerNumber is string && data.customerNumber.size() <= 500
             && data.company is string && data.company.size() <= 500
             && data.businessName is string && data.businessName.size() <= 500
             && data.latitude is number
             && data.longitude is number
             && data.createdAt == request.time
             && data.userId == request.auth.uid
             && (data.get('photoBase64', '') is string && data.get('photoBase64', '').size() <= 1048576);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['customerNumber', 'businessName', 'company', 'userId', 'updatedAt'])
             && data.customerNumber is string && data.customerNumber.size() <= 500
             && data.businessName is string && data.businessName.size() <= 500
             && data.company is string && data.company.size() <= 500
             && data.userId is string
             && data.updatedAt == request.time;
    }

    match /visits/{visitId} {
      allow create: if isSignedIn() && isValidVisit(incoming()) && isValidId(visitId);
      allow update: if false;
      allow delete: if isOwner(existing().userId);
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.token.email || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
